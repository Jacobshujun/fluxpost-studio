# Copy this file to deploy/env.production on the server and fill real values there.
# Do not commit deploy/env.production.

# Deployment controls. Keep proxy disabled until DNS points to this VPS.
FLUXPOST_PROXY_ENABLED=false
FLUXPOST_PUBLIC_HOST=
FLUXPOST_APP_PORT=3101

POSTGRES_DB=fluxpost_studio
POSTGRES_USER=fluxpost
POSTGRES_PASSWORD=change-this-long-random-password

TIKHUB_BASE_URL=https://api.tikhub.io
TIKHUB_API_KEY=

DATABASE_POOL_MAX=10
DATABASE_URL=postgres://fluxpost:change-this-long-random-password@postgres:5432/fluxpost_studio

WORKSPACE_AUTH_MODE=whitelist
WORKSPACE_ALLOWED_USERS=alice:Alice,bob:Bob
WORKSPACE_ADMIN_USERS=alice
WORKSPACE_ACCESS_PASSWORD=change-this-first-admin-setup-key

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_BASE_URL=
OPENAI_TEXT_ENDPOINT=responses
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_LIBRARY_TAGGING_MODEL=

OPENAI_IMAGE_BASE_URL=https://www.packyapi.com/v1
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BACKUP_BASE_URL=
OPENAI_IMAGE_BACKUP_API_KEY=
OPENAI_IMAGE_ENDPOINT=images
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_REQUEST_TIMEOUT_MS=180000

# Production server: local Klein/ComfyUI is intentionally unavailable.
FLUXPOST_KLEIN_AVAILABLE=false
COMFYUI_KLEIN_ENABLED=false
COMFYUI_BASE_URL=
COMFYUI_KLEIN_WORKFLOW_API_JSON=
COMFYUI_KLEIN_WORKFLOW_PATH=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BRAND=feishu
FEISHU_CLI_BIN=lark-cli
FEISHU_CLI_BITABLE_ARGS=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_FIELD_MAP=
FEISHU_CONTENT_IMPORT_BASE_TOKEN=
FEISHU_CONTENT_IMPORT_TABLE_ID=
FEISHU_CONTENT_IMPORT_FIELD_MAP=
FEISHU_DISTRIBUTION_CHECK_BASE_TOKEN=
FEISHU_DISTRIBUTION_CHECK_TABLE_ID=
FEISHU_DISTRIBUTION_CHECK_VIEW_ID=
FEISHU_DISTRIBUTION_CHECK_FIELD_MAP=
FEISHU_NOTIFY_CHAT_ID=
FEISHU_NOTIFY_USER_ID=

LARK_TASK_CHAT_IDS=
LARK_TASK_USER_MAP=
LARK_TASK_API_TOKEN=
LARK_TASK_DEFAULT_PLATFORMS=douyin,xiaohongshu
LARK_TASK_DEFAULT_COUNT=3
LARK_TASK_CONFIRM_ABOVE=20

ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_VIDEO_TRANSCRIPTION_MODEL=doubao-seed-2-0-lite-260428
ARK_VIDEO_TRANSCRIPTION_PROMPT=
ARK_VIDEO_TRANSCRIPTION_MAX_AUDIO_BYTES=125829120
