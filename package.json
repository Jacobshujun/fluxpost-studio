{
  "name": "social-content-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start -H 0.0.0.0 -p 3001",
    "local:restart": "powershell -ExecutionPolicy Bypass -File scripts/local/restart.ps1",
    "local:watch-simple": "powershell -ExecutionPolicy Bypass -File scripts/local/watch-simple-runs.ps1",
    "trellis:check": "powershell -ExecutionPolicy Bypass -File .trellis/verification/check.ps1",
    "lark:tasks": "node scripts/lark-task-runner.mjs",
    "lark:events": "node scripts/lark-task-events.mjs",
    "db:diagnose": "powershell -ExecutionPolicy Bypass -File scripts/local/postgres-diagnose.ps1",
    "db:migrate:postgres": "node scripts/db/migrate-sqlite-to-postgres.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "@volcengine/tos-sdk": "2.9.1",
    "lucide-react": "^1.16.0",
