# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local runtime data
/data/*.json
/data/*.db
/data/*.db-shm
/data/*.db-wal
/data/feishu-outbox/
/public/generated/
/public/media/
/test-artifacts/
/.tmp-*.json

# env files (can opt-in for committing if needed)
.env*
/deploy/env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
